{
  "$schema": "https://opencode.ai/config.json",
  "model": "sonnet",
  "small_model": "opencode/kimi-k2.5-free",
  "plugin": [
    "./plugins/git-worktree.ts",
    "./plugins/format-on-write.ts",
    "./plugins/ecc-hooks.ts"
  ],
  "agent": {
    "planner": {
      "description": "Read-only planning agent that decomposes tasks and creates spec artifacts",
      "mode": "subagent",
      "model": "sonnet",
      "temperature": 0.3,
      "prompt": "{file:.opencode/prompts/agents/planner.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "read": true,
        "search": true
      }
    },
    "builder": {
      "description": "Implementation agent that writes code strictly against specifications",
      "mode": "subagent",
      "model": "sonnet",
      "temperature": 0.1,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true
      }
    },
    "tester": {
      "description": "Test execution agent that runs tests and returns structured results",
      "mode": "subagent",
      "model": "haiku",
      "temperature": 0,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "read": true
      }
    },
    "reviewer": {
      "description": "Read-only code review agent that validates correctness, security, and spec compliance",
      "mode": "subagent",
      "model": "sonnet",
      "temperature": 0.2,
      "prompt": "{file:.opencode/prompts/agents/code-reviewer.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "read": true,
        "search": true
      }
    },
    "security": {
      "description": "Security review specialist for auth, payments, permissions, secrets, and crypto",
      "mode": "subagent",
      "model": "opus",
      "temperature": 0,
      "prompt": "{file:.opencode/prompts/agents/security-reviewer.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "read": true,
        "search": true
      }
    },
    "migration": {
      "description": "Database migration agent for schema diffs and dry-run migrations",
      "mode": "subagent",
      "model": "sonnet",
      "temperature": 0,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true
      }
    },
    "performance": {
      "description": "Performance optimization specialist",
      "mode": "subagent",
      "model": "sonnet",
      "temperature": 0.2,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true
      }
    },
    "refactor": {
      "description": "Code refactoring specialist for improvements and restructuring",
      "mode": "subagent",
      "model": "haiku",
      "temperature": 0.1,
      "prompt": "{file:.opencode/prompts/agents/refactor-cleaner.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true
      }
    },
    "debug": {
      "description": "Debug specialist for analyzing stack traces and root cause analysis",
      "mode": "subagent",
      "model": "sonnet",
      "temperature": 0.3,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "read": true,
        "search": true
      }
    },
    "release": {
      "description": "Release management agent for versioning, changelogs, and deployment coordination",
      "mode": "subagent",
      "model": "sonnet",
      "temperature": 0.2,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true,
        "search": true
      }
    },
    "documentation": {
      "description": "Documentation generation and maintenance agent",
      "mode": "subagent",
      "model": "haiku",
      "temperature": 0.2,
      "prompt": "{file:.opencode/prompts/agents/doc-updater.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
